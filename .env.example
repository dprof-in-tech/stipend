# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required for the Claude agent (claude-sonnet-4-6) and adversarial verifier (claude-haiku-4-5).
ANTHROPIC_API_KEY=sk-ant-...

# ── Trustless Work ─────────────────────────────────────────────────────────────
# Optional. Without these, the escrow flows use a realistic mock implementation.
TW_API_BASE=https://api.trustlesswork.com
TW_API_KEY=

# URL base for Escrow Viewer deep links (shown in the UI)
TW_VIEWER_BASE=https://escrow-viewer.trustlesswork.com

# ── Stellar ────────────────────────────────────────────────────────────────────
# Server-managed Stellar public keys for agent and verifier wallets.
# In production, derive from secret keys via @stellar/stellar-sdk Keypair.
AGENT_STELLAR_PUBLIC_KEY=
VERIFIER_STELLAR_PUBLIC_KEY=
STELLAR_NETWORK=testnet

# ── x402 Payment Protocol ──────────────────────────────────────────────────────
# The x402 npm package handles the HTTP 402 payment protocol for web searches.
# Supported networks: EVM chains (base-sepolia testnet) — NOT Stellar (v2 roadmap).
#
# Search endpoint (defaults to local /api/x402/search mock):
X402_SEARCH_ENDPOINT=http://localhost:3000/api/x402/search
#
# Agent's EVM address on Base Sepolia (for payment headers):
AGENT_EVM_ADDRESS=0x...
#
# Recipient EVM address for the x402 search service:
SEARCH_RECIPIENT_EVM_ADDRESS=0x...
#
# Optional: Coinbase x402 facilitator URL for real on-chain settlement.
# When set, payment headers are verified against Base Sepolia blockchain state.
# Without this, the server accepts structurally valid mock payments (demo mode).
X402_FACILITATOR_URL=
# Example: X402_FACILITATOR_URL=https://x402.org/facilitator

# ── Optional: OpenAI for cross-provider verifier ────────────────────────────────
OPENAI_API_KEY=
