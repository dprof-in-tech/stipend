# ── Trustless Work ─────────────────────────────────────────────────────────────
# Get your API key from https://dapp.dev.trustlesswork.com (testnet)
# or https://dapp.trustlesswork.com (mainnet).
# Without TW_API_KEY, escrow flows run in realistic mock mode.
TW_API_BASE=https://dev.api.trustlesswork.com
TW_API_KEY=

# URL base for Escrow Viewer deep links (shown in the UI)
TW_VIEWER_BASE=https://escrow-viewer.trustlesswork.com

# ── Stellar keypairs ────────────────────────────────────────────────────────────
# The platform wallet signs all escrow transactions (approver, releaseSigner, disputeResolver).
# The agent wallet is the serviceProvider and payment receiver.
#
# Generate testnet keypairs:
#   node -e "const {Keypair}=require('@stellar/stellar-sdk');const k=Keypair.random();console.log(k.publicKey(),k.secret())"
# Fund with XLM on testnet:
#   curl "https://friendbot.stellar.org?addr=<PUBLIC_KEY>"
PLATFORM_STELLAR_PUBLIC_KEY=GAJAPRMZJIESF5LH7V6RHKHWAX6YFTQBV3FEH6263FSXTFAYLYQC5R4A
PLATFORM_STELLAR_SECRET=SBQXT3ZDBFL3RGE5FQ7MT4GCP5PFY5BRJEBZEAMU5SBZWEDRRT2VQQZ7

AGENT_STELLAR_PUBLIC_KEY=GBJNCBK4WKDQXLDGTFYIHYIIE2MVUQUJ2H5OTV3FOMRNYIOTVJXMD5JR
AGENT_STELLAR_SECRET=SBP6XSZFVCDTZN3JHJXKGQZFC53FSKKKXB4JXQJCAV54GVP5GBTXWGJL

STELLAR_NETWORK=testnet

# USDC issuer on Stellar
# Testnet (Circle test issuer): GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
USDC_STELLAR_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# ── x402 Payment Protocol ──────────────────────────────────────────────────────
# EVM-chain micropayments for web search tool costs (base-sepolia testnet).
# Separate from the Stellar escrow layer.
X402_SEARCH_ENDPOINT=http://localhost:3000/api/x402/search
AGENT_EVM_ADDRESS=0x...
SEARCH_RECIPIENT_EVM_ADDRESS=0x...
# Optional: real on-chain settlement via Coinbase x402 facilitator
X402_FACILITATOR_URL=
# Example: X402_FACILITATOR_URL=https://x402.org/facilitator

# ── Firecrawl (JS-rendered page scraping) ─────────────────────────────────────
# Used as fallback when web_fetch hits a JS SPA or Cloudflare-protected page.
# Get a free key (500 scrapes/month) at https://firecrawl.dev
# Without this key, blocked URLs return a plain unavailable message.
FIRECRAWL_API_KEY=

# ── Optional: OpenAI for cross-provider verifier ────────────────────────────────
OPENAI_API_KEY=

# ── Vercel AI Gateway (Unified Key) ───────────────────────────────────────────
# Use a single key for all models (OpenAI, Anthropic, Google, etc.)
# Get yours from the Vercel Dashboard.
AI_GATEWAY_API_KEY=

