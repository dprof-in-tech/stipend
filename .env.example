# Anthropic API key for Claude agent and verifier
ANTHROPIC_API_KEY=sk-ant-...

# Trustless Work API (https://api.trustlesswork.com)
TW_API_BASE=https://api.trustlesswork.com
TW_API_KEY=

# Server-managed Stellar accounts (base58 secret seeds)
AGENT_STELLAR_SECRET=
VERIFIER_STELLAR_SECRET=

# Escrow Viewer base URL for deep links
TW_VIEWER_BASE=https://escrow-viewer.trustlesswork.com

# x402 mock search endpoint (set to /api/x402/search for local mock)
X402_SEARCH_ENDPOINT=http://localhost:3000/api/x402/search

# Optional: OpenAI key for cross-provider verifier (leave empty to use Claude)
OPENAI_API_KEY=
